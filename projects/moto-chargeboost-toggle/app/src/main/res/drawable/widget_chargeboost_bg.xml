<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#163126"
                android:centerColor="#1F5A3B"
                android:endColor="#2E7D32" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#14000000" />
            <corners android:radius="19dp" />
            <stroke
                android:width="1dp"
                android:color="#55FFFFFF" />
        </shape>
    </item>

    <item
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#22FFFFFF"
                android:endColor="#08FFFFFF" />
        </shape>
    </item>
</layer-list>
